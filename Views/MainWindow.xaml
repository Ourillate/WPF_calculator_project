<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Calculator"
        xmlns:vm="clr-namespace:Calculator.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="600" Width="400"
        MinHeight="300" MinWidth="200"
        Background="#1E1E1E"
        FontFamily="Segoe UI">

    <!-- ViewModel -->
    <Window.DataContext>
        <vm:CalculatorViewModel/>
    </Window.DataContext>

    <!-- ===================== СТИЛИ КНОПОК ===================== -->
    <Window.Resources>

        <!-- Базовый стиль всех кнопок -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Серые кнопки -->
        <Style x:Key="GrayBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#3A3A3D" Offset="0"/>
                        <GradientStop Color="#2B2B2E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Темные кнопки -->
        <Style x:Key="DarkGrayBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#292929" Offset="0"/>
                        <GradientStop Color="#242427" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Оранжевые кнопки -->
        <Style x:Key="OrangeBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFB347" Offset="0"/>
                        <GradientStop Color="#FF7A00" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ===================== ОСНОВНАЯ СЕТКА ===================== -->
    <Grid Margin="10">

        <!-- Верх: экран | Низ: кнопки -->
        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- ===================== ПОЛЕ КНОПОК ===================== -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- ===================== СЛУЖЕБНЫЕ КНОПКИ ===================== -->
            <Button Style="{StaticResource DarkGrayBtn}"
                    Content="CE"
                    Command="{Binding ClearCommand}"
                    CommandParameter="CE"
                    Grid.Column="0" Grid.Row="0"/>
            <Button Style="{StaticResource DarkGrayBtn}"
                    Content="C"
                    Command="{Binding ClearCommand}"
                    CommandParameter="C"
                    Grid.Column="1" Grid.Row="0"/>
            <Button Style="{StaticResource DarkGrayBtn}"
                    Content="←"
                    Command="{Binding ClearCommand}"
                    CommandParameter="BS"
                    Grid.Column="2" Grid.Row="0"/>

            <!-- ===================== ОПЕРАЦИИ ===================== -->
            <Button Style="{StaticResource OrangeBtn}"
                    Content="×"
                    Command="{Binding OperationCommand}"
                    CommandParameter="*"
                    Grid.Column="3" Grid.Row="1"/>
            <Button Style="{StaticResource OrangeBtn}"
                    Content="-"
                    Command="{Binding OperationCommand}"
                    CommandParameter="-"
                    Grid.Column="3" Grid.Row="2"/>
            <Button Style="{StaticResource OrangeBtn}"
                    Content="+"
                    Command="{Binding OperationCommand}"
                    CommandParameter="+"
                    Grid.Column="3" Grid.Row="3"/>
            <Button Style="{StaticResource OrangeBtn}"
                    Content="÷"
                    Command="{Binding OperationCommand}"
                    CommandParameter="/"
                    Grid.Column="3" Grid.Row="0"/>
            <Button Style="{StaticResource OrangeBtn}"
                    Content="="
                    Command="{Binding EvaluateCommand}"
                    Grid.Column="3" Grid.Row="4"/>

            <!-- ===================== ЦИФРЫ ===================== -->
            <Button Style="{StaticResource GrayBtn}"
                    Content="7"
                    Command="{Binding AddCommand}"
                    CommandParameter="7"
                    Grid.Column="0" Grid.Row="1"/>
            <Button Style="{StaticResource GrayBtn}"
                    Content="8"
                    Command="{Binding AddCommand}"
                    CommandParameter="8"
                    Grid.Column="1" Grid.Row="1"/>
            <Button Style="{StaticResource GrayBtn}"
                    Content="9"
                    Command="{Binding AddCommand}"
                    CommandParameter="9"
                    Grid.Column="2" Grid.Row="1"/>
            <Button Style="{StaticResource GrayBtn}"
                    Content="4"
                    Command="{Binding AddCommand}"
                    CommandParameter="4"
                    Grid.Column="0" Grid.Row="2"/>
            <Button Style="{StaticResource GrayBtn}"
                    Content="5"
                    Command="{Binding AddCommand}"
                    CommandParameter="5"
                    Grid.Column="1" Grid.Row="2"/>
            <Button Style="{StaticResource GrayBtn}"
                    Content="6"
                    Command="{Binding AddCommand}"
                    CommandParameter="6"
                    Grid.Column="2" Grid.Row="2"/>
            <Button Style="{StaticResource GrayBtn}"
                    Content="1"
                    Command="{Binding AddCommand}"
                    CommandParameter="1"
                    Grid.Column="0" Grid.Row="3"/>
            <Button Style="{StaticResource GrayBtn}"
                    Content="2"
                    Command="{Binding AddCommand}"
                    CommandParameter="2"
                    Grid.Column="1" Grid.Row="3"/>
            <Button Style="{StaticResource GrayBtn}"
                    Content="3"
                    Command="{Binding AddCommand}"
                    CommandParameter="3"
                    Grid.Column="2" Grid.Row="3"/>
            <Button Style="{StaticResource GrayBtn}"
                    Content="0"
                    Command="{Binding AddCommand}"
                    CommandParameter="0"
                    Grid.Column="1" Grid.Row="4"/>
            <Button Style="{StaticResource GrayBtn}"
                    Content=","
                    Command="{Binding AddCommand}"
                    CommandParameter=","
                    Grid.Column="2" Grid.Row="4"/>
            <Button Style="{StaticResource GrayBtn}"
                    Content="±"
                    Command="{Binding UnaryMinusCommand}"
                    CommandParameter="Y"
                    Grid.Column="0" Grid.Row="4"/>
        </Grid>

        <!-- ===================== ЭКРАН ВЫВОДА ===================== -->
        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,5">
            <TextBlock Foreground="#AFAFAF"
                       FontSize="24"
                       HorizontalAlignment="Right"
                       Text="{Binding SecondInputString}"/>
            <TextBlock Foreground="#E5E5E5"
                       FontSize="40"
                       HorizontalAlignment="Right"
                       Text="{Binding MainInputString}"/>
        </StackPanel>
    </Grid>
</Window>